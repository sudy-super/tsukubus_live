{
  "name": "bus_livemap",
  "version": "1.0.0",
  "description": "筑波大学循環のライブマップ",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "predev:server": "node scripts/generate-runtime-data.mjs",
    "dev:server": "node --watch src/server.js",
    "dev:client": "vite",
    "prebuild": "node scripts/generate-runtime-data.mjs",
    "build": "vite build",
    "prestart": "node scripts/generate-runtime-data.mjs",
    "start": "node src/server.js",
    "dev:cf": "wrangler dev",
    "deploy:cf": "wrangler deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  }
}
